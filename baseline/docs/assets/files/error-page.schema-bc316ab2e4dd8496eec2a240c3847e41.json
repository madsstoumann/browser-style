{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "id": "error-page",
  "title": "⚠️ Error Page",
  "description": "Maps an HTTP status code to a custom error page",
  "metadata": {
    "version": "1.0.0",
    "lastModified": "2026-03-22",
    "displayField": "internalName"
  },
  "type": "object",
  "properties": {
    "internalName": {
      "type": "string",
      "title": "Internal Name",
      "description": "Internal name for CMS editors — not displayed on the front end",
      "localized": false,
      "validation": {
        "required": true
      }
    },
    "status_code": {
      "type": "select",
      "title": "Status Code",
      "description": "HTTP status code this error page handles",
      "options": [
        { "value": "401", "label": "401 — Unauthorized" },
        { "value": "403", "label": "403 — Forbidden" },
        { "value": "404", "label": "404 — Not Found" },
        { "value": "410", "label": "410 — Gone" },
        { "value": "500", "label": "500 — Internal Server Error" },
        { "value": "503", "label": "503 — Service Unavailable" }
      ]
    },
    "page_id": {
      "type": "reference",
      "title": "Page",
      "description": "The page to render for this error code",
      "options": {
        "referenceType": "page",
        "multiple": false
      }
    }
  },
  "required": [
    "status_code",
    "page_id"
  ]
}
