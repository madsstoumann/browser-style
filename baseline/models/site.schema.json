{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "id": "site",
  "title": "Site",
  "description": "Site-wide singleton configuration (only one record)",
  "metadata": {
    "version": "3.0.0",
    "lastModified": "2026-03-22",
    "displayField": "site_name",
    "singleton": true
  },
  "structure": {
    "allowedAsRoot": true,
    "layout": [
      {
        "area": "main",
        "type": "group",
        "name": "Identity & Business",
        "description": "Basic site configuration",
        "collapse": false,
        "fields": ["site_name", "site_url", "default_locale", "legal_name", "contact_email", "contact_phone", "address", "privacy_policy_id", "terms_service_id", "social_links"]
      },
      {
        "area": "main",
        "type": "group",
        "name": "External Scripts",
        "description": "Third-party scripts: analytics, consent, marketing, support",
        "collapse": true,
        "fields": ["external_scripts"]
      },
      {
        "area": "main",
        "type": "group",
        "name": "Icons",
        "description": "Favicon and touch icons (used in HTML <head>)",
        "collapse": true,
        "fields": ["favicon", "favicon_svg", "apple_touch_icon"]
      },
      {
        "area": "main",
        "type": "group",
        "name": "SEO & Social",
        "description": "Default SEO and Open Graph settings",
        "collapse": true,
        "fields": ["site_description", "og_image"]
      },
      {
        "area": "main",
        "type": "group",
        "name": "Navigation",
        "description": "Default site navigation settings",
        "collapse": true,
        "fields": ["header_nav_id", "footer_nav_id"]
      },
      {
        "area": "main",
        "type": "group",
        "name": "Error Pages",
        "description": "Custom error page references",
        "collapse": true,
        "fields": ["error_pages"]
      },
      {
        "area": "main",
        "type": "group",
        "name": "Configuration",
        "description": "Security, headers, and crawler configuration",
        "collapse": true,
        "fields": ["crawler_config_id", "headers_config_id", "security_config_id"]
      },
      {
        "area": "main",
        "type": "group",
        "name": "Personas",
        "description": "Search persona definitions",
        "collapse": true,
        "fields": ["personas"]
      }
    ]
  },
  "type": "object",
  "properties": {
    "site_name": {
      "type": "string",
      "title": "Site Name",
      "description": "Site name",
      "localized": false
    },
    "site_url": {
      "type": "string",
      "title": "Site URL",
      "description": "Site base URL (e.g., \"https://example.com\")",
      "localized": false
    },
    "site_description": {
      "type": "string",
      "title": "Site Description",
      "description": "Default meta description for the site"
    },
    "default_locale": {
      "type": "string",
      "title": "Default Locale",
      "description": "Fallback locale and source language for translations (e.g. 'en-US')",
      "default": "en-US",
      "localized": false
    },
    "external_scripts": {
      "type": "reference",
      "title": "External Scripts",
      "description": "Third-party scripts (analytics, consent, marketing, support, etc.)",
      "options": {
        "referenceType": "external-script",
        "multiple": true
      }
    },
    "legal_name": {
      "type": "string",
      "title": "Legal Name",
      "description": "Official business name (e.g. 'Browser Style Ltd.')",
      "localized": false
    },
    "contact_email": {
      "type": "string",
      "title": "Contact Email",
      "description": "Public contact email address",
      "localized": false
    },
    "contact_phone": {
      "type": "string",
      "title": "Contact Phone",
      "description": "Public phone number",
      "localized": false
    },
    "address": {
      "type": "text",
      "title": "Address",
      "description": "Physical business address",
      "localized": false
    },
    "privacy_policy_id": {
      "type": "reference",
      "title": "Privacy Policy",
      "description": "Link to the Privacy Policy page",
      "options": {
        "referenceType": "page",
        "multiple": false
      }
    },
    "terms_service_id": {
      "type": "reference",
      "title": "Terms of Service",
      "description": "Link to the Terms of Service page",
      "options": {
        "referenceType": "page",
        "multiple": false
      }
    },
    "social_links": {
      "type": "reference",
      "title": "Social Profiles",
      "description": "Social media profile links",
      "options": {
        "referenceType": "social-link",
        "multiple": true
      }
    },
    "favicon": {
      "type": "media",
      "title": "Favicon",
      "description": "Favicon (favicon.ico, 32x32)"
    },
    "favicon_svg": {
      "type": "media",
      "title": "Favicon SVG",
      "description": "SVG favicon (scalable, modern browsers)"
    },
    "apple_touch_icon": {
      "type": "media",
      "title": "Apple Touch Icon",
      "description": "Apple touch icon (180x180 recommended)"
    },
    "og_image": {
      "type": "media",
      "title": "Open Graph Image",
      "description": "Fallback Open Graph image"
    },
    "header_nav_id": {
      "type": "reference",
      "title": "Default Header Navigation",
      "description": "Default header navigation reference",
      "options": {
        "referenceType": "navigation",
        "multiple": false
      }
    },
    "footer_nav_id": {
      "type": "reference",
      "title": "Default Footer Navigation",
      "description": "Default footer navigation reference",
      "options": {
        "referenceType": "navigation",
        "multiple": false
      }
    },
    "error_pages": {
      "type": "reference",
      "title": "Error Pages",
      "description": "Custom error pages mapped by HTTP status code (404, 500, 401, etc.)",
      "options": {
        "referenceType": "error-page",
        "multiple": true
      }
    },
    "crawler_config_id": {
      "type": "reference",
      "title": "Crawler Config",
      "description": "Crawler, manifest, and LLM index configuration",
      "options": {
        "referenceType": "crawler-config",
        "multiple": false
      }
    },
    "headers_config_id": {
      "type": "reference",
      "title": "Headers Config",
      "description": "HTTP security and privacy headers configuration",
      "options": {
        "referenceType": "headers-config",
        "multiple": false
      }
    },
    "security_config_id": {
      "type": "reference",
      "title": "Security Config",
      "description": "Security contact and vulnerability disclosure configuration",
      "options": {
        "referenceType": "security-config",
        "multiple": false
      }
    },
    "personas": {
      "type": "reference",
      "title": "Personas",
      "description": "Search personas for audience-specific content retrieval",
      "options": {
        "referenceType": "persona",
        "multiple": true
      }
    }
  },
  "required": [
    "site_name",
    "site_url"
  ]
}