# Vercel + Contentful Environment Configuration
# Copy this file to .env.local in your Next.js project
# DO NOT commit .env.local to version control
#
# See docs/WEBHOOK-EDGE-PLAN.md for full architecture details

# ============================================================================
# CONTENTFUL
# ============================================================================
# Space ID — find at: Contentful → Settings → General Settings
# CONTENTFUL_SPACE_ID=your_space_id

# Environment (default: master)
# CONTENTFUL_ENVIRONMENT=master

# Content Management API token (for webhook handlers that fetch entries)
# Create at: Contentful → Settings → API Keys → Content management tokens
# CONTENTFUL_ACCESS_TOKEN=your_cma_token

# Content Delivery API token (for read-only fetches in prebuild/ISR)
# Create at: Contentful → Settings → API Keys → Add API Key
# CONTENTFUL_DELIVERY_TOKEN=your_cda_token

# Content Preview API token (for draft content in preview mode)
# CONTENTFUL_PREVIEW_TOKEN=your_cpa_token

# ============================================================================
# VERCEL EDGE CONFIG
# ============================================================================
# Connection string for reading Edge Config (provided by Vercel)
# Find at: Vercel Dashboard → Storage → Edge Config → Connect
# EDGE_CONFIG=https://edge-config.vercel.com/ecfg_xxxxxxxxxxxxx

# Edge Config ID for the write API
# EDGE_CONFIG_ID=ecfg_xxxxxxxxxxxxx

# Vercel API token with Edge Config write permissions
# Create at: Vercel Dashboard → Account Settings → Tokens
# VERCEL_API_TOKEN=your_vercel_api_token

# ============================================================================
# DEPLOY HOOK
# ============================================================================
# Triggers a rebuild when sitemap, llms, or translation settings change
# Create at: Vercel Dashboard → Project → Settings → Git → Deploy Hooks
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxxxxxxxxxxxx/xxxxxxxxxx

# ============================================================================
# SITE & BUILD
# ============================================================================
# Public site URL (used for sitemap.xml, llms.txt, and Open Graph URLs)
# NEXT_PUBLIC_SITE_URL=https://example.com

# Comma-separated list of active locales
# Used by the prebuild script to generate locales/{locale}.json files
# LOCALES=en-US,da-DK,de-DE

# ============================================================================
# WEBHOOK SECURITY
# ============================================================================
# Shared secret for validating inbound CMS webhooks
# Used by /api/webhook/cms to verify webhook signatures
# Must match the secret configured in your Contentful webhook settings
# CMS_WEBHOOK_SECRET=your_webhook_signing_secret
