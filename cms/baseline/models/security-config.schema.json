{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "id": "security-config",
  "title": "🛠️ Security Config",
  "description": "Security contact and vulnerability disclosure configuration",
  "metadata": {
    "version": "1.0.0",
    "lastModified": "2026-03-16",
    "displayField": "internalName",
    "singleton": true
  },
  "structure": {
    "allowedAsRoot": true,
    "contentTree": {
      "folder": "Configuration",
      "path": "Configuration/Security"
    }
  },
  "type": "object",
  "properties": {
    "internalName": {
      "type": "string",
      "title": "Internal Name",
      "description": "Internal name for CMS editors — not displayed on the front end",
      "localized": false,
      "validation": {
        "required": true
      }
    },
    "title": {
      "type": "string",
      "title": "Title",
      "description": "Editorial label for this configuration",
      "localized": false
    },
    "security_txt": {
      "type": "text",
      "title": "security.txt",
      "description": "security.txt content (served at /.well-known/security.txt)",
      "localized": false,
      "ui": {
        "widget": "editor-security"
      }
    }
  },
  "required": ["title"]
}