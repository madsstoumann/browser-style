{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "id": "crawler-config",
  "title": "🛠️ Crawler Config",
  "description": "Configuration for generated static files: robots.txt, manifest.json, sitemap.xml, and llms.txt",
  "metadata": {
    "version": "1.1.0",
    "lastModified": "2026-03-22",
    "displayField": "internalName",
    "singleton": true
  },
  "structure": {
    "allowedAsRoot": true,
    "contentTree": {
      "folder": "Configuration",
      "path": "Configuration/Crawler"
    },
    "layout": [
      {
        "area": "main",
        "type": "group",
        "name": "robots.txt",
        "description": "Crawler directives",
        "collapse": false,
        "fields": ["internalName", "robots_txt"]
      },
      {
        "area": "main",
        "type": "group",
        "name": "Web App Manifest",
        "description": "Progressive Web App manifest configuration and icons",
        "collapse": true,
        "fields": ["manifest", "app_icon_small", "app_icon_medium", "app_icon_large"]
      },
      {
        "area": "main",
        "type": "group",
        "name": "LLM Index",
        "description": "llms.txt and llms-full.txt generation settings",
        "collapse": true,
        "fields": ["llms_enabled", "llms_preamble", "llms_exclude_patterns"]
      }
    ]
  },
  "type": "object",
  "properties": {
    "internalName": {
      "type": "string",
      "title": "Internal Name",
      "description": "Internal name for CMS editors — not displayed on the front end",
      "localized": false,
      "validation": {
        "required": true
      }
    },
    "title": {
      "type": "string",
      "title": "Title",
      "description": "Editorial label for this configuration",
      "localized": false
    },
    "robots_txt": {
      "type": "text",
      "title": "Directives",
      "description": "robots.txt content",
      "localized": false,
      "ui": {
        "widget": "editor-robots"
      }
    },
    "manifest": {
      "type": "object",
      "title": "Web App Manifest",
      "description": "manifest.json configuration",
      "ui": {
        "widget": "editor-manifest"
      }
    },
    "app_icon_small": {
      "type": "media",
      "title": "App Icon Small",
      "description": "PWA / manifest icon (192x192 recommended)"
    },
    "app_icon_medium": {
      "type": "media",
      "title": "App Icon Medium",
      "description": "PWA / manifest icon (384x384 recommended)"
    },
    "app_icon_large": {
      "type": "media",
      "title": "App Icon Large",
      "description": "PWA / manifest icon (512x512 recommended, also used for splash screens)"
    },
    "llms_enabled": {
      "type": "boolean",
      "title": "Enable llms.txt",
      "description": "Generate llms.txt and llms-full.txt endpoints",
      "default": true
    },
    "llms_preamble": {
      "type": "text",
      "title": "llms.txt Preamble",
      "description": "Introductory block at the top of llms.txt (what the site is, who it's for)",
      "localized": false
    },
    "llms_exclude_patterns": {
      "type": "array",
      "title": "Exclude from LLM Index",
      "description": "URL patterns to exclude from llms.txt and llms-full.txt (e.g. '/admin/*', '/preview/*')",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["title"]
}